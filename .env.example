# ===========================================
# AgentClave — Governed Agent Runtime
# ===========================================
# Copy this file to .env and update the values.

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentclave_dev
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agentclave_dev
POSTGRES_PORT=5432
POSTGRES_CONTAINER=postgres-local
POSTGRES_ADMIN_DB=postgres

# ===========================================
# Better Auth
# ===========================================
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5100

# ===========================================
# OAuth (Optional)
# ===========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# App Settings
NODE_ENV=development

# ===========================================
# Redis (BullMQ queue backend)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# OpenRouter (LLM provider)
# ===========================================
OPENROUTER_API_KEY=your-openrouter-api-key

# ===========================================
# Credential Encryption
# ===========================================
CREDENTIAL_ENCRYPTION_KEY=change-this-to-a-random-32-char-string-at-least

# ===========================================
# Telegram Bot (Optional — for live demo)
# ===========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MANAGER_CHAT_ID=

# ===========================================
# Demo Inventory API
# ===========================================
DEMO_INVENTORY_API_BASE_URL=http://localhost:4301
DEMO_INVENTORY_API_KEY=demo-inventory-key

# ===========================================
# Frontend Environment Variables
# ===========================================
VITE_API_URL=http://localhost:4000

# ===========================================
# S3-Compatible Object Storage (MinIO local / R2 prod)
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=agentclave-dev
S3_FORCE_PATH_STYLE=true
S3_MAX_UPLOAD_BYTES=26214400
S3_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,application/pdf,text/plain,text/csv,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
