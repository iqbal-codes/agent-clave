{
	"name": "agentclave",
	"private": true,
	"description": "Governed agent runtime for internal operations",
	"packageManager": "pnpm@9.15.0",
	"type": "module",
	"scripts": {
		"dev": "./scripts/dev.sh",
		"build": "vp run -r build",
		"check-types": "vp run -r check-types",
		"dev:api": "vp run --filter ./apps/api dev",
		"dev:web": "vp dev apps/web",
		"dev:worker": "vp run --filter ./apps/worker dev",
		"dev:demo-inventory-api": "vp run --filter ./apps/demo-inventory-api dev",
		"db:studio": "vp run --filter ./packages/db db:studio",
		"db:generate": "vp run --filter ./packages/db db:generate",
		"db:push": "vp run --filter ./packages/db db:push",
		"db:check": "./scripts/db-setup.sh status",
		"check": "vp check --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:reset": "docker compose down -v && docker compose up -d postgres",
		"docker:logs": "docker compose logs -f postgres",
		"db:setup": "./scripts/db-setup.sh start && vp run --filter ./packages/db db:push",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:report": "playwright show-report",
		"prepare": "vp config"
	},
	"dependencies": {
		"@agentclave/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@agentclave/config": "workspace:*",
		"@agentclave/types": "workspace:*",
		"@types/bun": "^1.3.14",
		"typescript": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"overrides": {
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
